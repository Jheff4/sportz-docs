        {
          "anchor": "Frontend Repo",
          "href": "https://github.com/Jheff4/sportz-ui",
          "icon": "browser"
        }
      ]
    }
  },
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg"
  },
  "navbar": {
    "primary": {
      "type": "github",
      "href": "https://github.com/Jheff4/sportz-websockets"
    }
  },
  "contextual": {
    "options": [
      "copy",
      "view",
      "chatgpt",
      "claude"
    ]
  },
  "footer": {
    "socials": {
      "github": "https://github.com/Jheff4"
    }
  }
}
